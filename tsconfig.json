      "vue-lynx/main-thread": ["./packages/vue-lynx/main-thread/src/entry-main.ts"],
      "vue-lynx/entry-background": ["./packages/vue-lynx/runtime/src/entry-background.ts"],
      "vue-lynx/plugin": ["./packages/vue-lynx/plugin/src/index.ts"]
    }
  }
}

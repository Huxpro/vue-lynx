{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "incremental": true,
    "useDefineForClassFields": true,
    "allowJs": false,
    "checkJs": false,
    "declaration": true,
    "sourceMap": true,
    "stripInternal": true,
    "verbatimModuleSyntax": true,
    "isolatedDeclarations": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "references": [
    { "path": "./runtime/tsconfig.build.json" },
    { "path": "./main-thread/tsconfig.build.json" },
    { "path": "./plugin/tsconfig.build.json" },
    { "path": "./internal/tsconfig.json" }
  ],
  "include": []
}

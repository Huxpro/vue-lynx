{
  "name": "vue-lynx-benchmark",
  "version": "0.0.0",
  "private": true,
  "description": "Unified Vue Lynx benchmark matrix (IFR × VDOM/Vapor × React) on Lynx for Web — table interaction, storms, and synthesis with ifr-bench FCP",
  "type": "module",
  "scripts": {
    "build": "node harness/build.mjs",
    "build:unified": "node harness/build-unified.mjs",
    "bench": "node harness/run.mjs",
    "bench:quick": "node harness/run.mjs --startup-count 2",
    "bench:cross": "node harness/cross.mjs",
    "bench:cross:quick": "node harness/cross.mjs --loads 1 --count 5",
    "bench:storms": "node harness/cross.mjs --storms",
    "bench:unified": "node harness/unified.mjs --campaign focused",
    "bench:unified:smoke": "node harness/unified.mjs --campaign smoke",
    "bench:unified:full": "node harness/unified.mjs --campaign full",
    "bench:synthesize": "node harness/synthesize.mjs",
    "bench:report": "node harness/report-unified.mjs"
  },
  "dependencies": {
    "vue-lynx": "workspace:*"
  },
  "devDependencies": {
    "@lynx-js/rspeedy": "^0.13.5",
    "@lynx-js/web-core": "^0.22.1",
    "@lynx-js/web-elements": "^0.12.5",
    "@rsbuild/plugin-vue": "^1.2.6",
    "playwright-core": "^1.49.0",
    "sirv": "^2.0.4",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "vue-lynx-benchmark",
  "version": "0.0.0",
  "private": true,
  "description": "VDOM vs Vapor benchmark on Lynx — port of vuejs/core packages-private/benchmark (js-framework-benchmark derived) running on Lynx for Web",
  "type": "module",
  "scripts": {
    "build": "node harness/build.mjs",
    "bench": "node harness/run.mjs",
    "bench:quick": "node harness/run.mjs --count 5 --startup-count 2"
  },
  "dependencies": {
    "vue-lynx": "workspace:*"
  },
  "devDependencies": {
    "@lynx-js/rspeedy": "^0.13.5",
    "@lynx-js/web-core": "^0.20.0",
    "@lynx-js/web-elements": "^0.12.0",
    "@rsbuild/plugin-vue": "^1.2.6",
    "playwright-core": "^1.49.0",
    "sirv": "^2.0.4",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}

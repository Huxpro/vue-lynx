{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "incremental": true,
    "useDefineForClassFields": true,
    "allowJs": false,
    "checkJs": false,
    "declaration": true,
    "sourceMap": true,
    "stripInternal": true,
    "verbatimModuleSyntax": true,
    "isolatedDeclarations": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "vue-lynx": ["./runtime/src/index.ts"],
      "vue-lynx/internal/ops": ["./internal/src/ops.ts"],
      "vue-lynx/main-thread": ["./main-thread/src/entry-main.ts"],
      "vue-lynx/entry-background": ["./runtime/src/entry-background.ts"],
      "vue-lynx/plugin": ["./plugin/src/index.ts"]
    }
  },
  "references": [
    { "path": "./runtime/tsconfig.build.json" },
    { "path": "./main-thread/tsconfig.build.json" },
    { "path": "./plugin/tsconfig.build.json" },
    { "path": "./internal/tsconfig.json" }
  ],
  "include": []
}

{
  "$schema": "https://unpkg.com/@changesets/config@3.1.0/schema.json",
  "changelog": [
    "@svitejs/changesets-changelog-github-compact",
    {
      "repo": "Huxpro/vue-lynx"
    }
  ],
  "commit": false,
  "fixed": [],

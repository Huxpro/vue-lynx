{
  "name": "@vue-lynx-example/genui-playground",
  "version": "0.1.0",
  "private": true,
  "description": "Vue-Lynx GenUI playground: web IDE-style shell (ported from lynx-family/lynx-stack) driving Vue Lynx A2UI/OpenUI bundles",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "pnpm run build:lynx && rsbuild build",
    "build:lynx": "rspeedy build",
    "dev": "pnpm run build:lynx && rsbuild dev",
    "dev:lynx": "rspeedy dev",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@lynx-js/luna-styles": "^0.2.0",
    "@lynx-js/web-core": "^0.20.0",
    "@lynx-js/web-elements": "^0.12.0",
    "@openuidev/lang-core": "^0.2.7",
    "@uiw/react-codemirror": "^4.25.9",
    "idb": "^8.0.3",
    "lucide-react": "^0.575.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vaul": "^1.1.2",
    "vue-lynx": "workspace:*",
    "vue-lynx-genui": "workspace:*"
  },
  "devDependencies": {
    "@lynx-js/rspeedy": "^0.13.5",
    "@rsbuild/core": "^1.7.3",
    "@rsbuild/plugin-react": "^1.4.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
